flowchart TD
    subgraph Build["Import-Time Parser Construction"]
        G["Parser/grammer.txt"]
        FID["fill_nterminal_id_dict"]
        RTS["rule_to_states"]
        IDS["id_state_dict"]
        NFS["nterminal_first_state"]
        G --> FID
        G --> RTS
        FID --> RTS
        RTS --> IDS
        RTS --> NFS
    end

